# ML Tagger - Environment Configuration
# Copy this file to .env and adjust values as needed.

# ---- Database ----
POSTGRES_DB=ml_tagger
POSTGRES_USER=tagger
POSTGRES_PASSWORD=tagger_dev_password

# ---- Redis ----
REDIS_PASSWORD=redis_dev_password

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO
API_SECRET_KEY=dev_secret_key_change_in_production
CORS_ORIGINS=http://localhost:3000

# ---- Processing ----
MAX_CONCURRENT_JOBS=3
JOB_TIMEOUT_SECONDS=1800

# ---- Sampling ----
SAMPLE_FPS=0.5
MAX_FRAMES_PER_SCENE=100
SAMPLE_QUALITY=medium
CACHE_FRAMES=true
FFMPEG_THREADS=2
FFMPEG_TIMEOUT=300

# ---- Vision / Embeddings ----
VISION_MODEL=clip-vit-base-patch32
VISION_DEVICE=auto
EMBEDDINGS_BATCH_SIZE=4
CLIP_MODEL_NAME=laion/CLIP-ViT-L-14-laion2B-s32B-b82K

# ---- ASR (speech-to-text) ----
ASR_MODEL=whisper-small
ASR_DEVICE=auto
ASR_LANGUAGE=en

# ---- OCR ----
OCR_ENGINE=paddleocr
OCR_LANGUAGES=en

# ---- Fusion / Scoring ----
MIN_AGREEMENT_FRAMES=3
TEMPORAL_WINDOW_SECONDS=10
VISION_WEIGHT=0.7
ASR_WEIGHT=0.2
OCR_WEIGHT=0.1
DEFAULT_REVIEW_THRESHOLD=0.3
DEFAULT_AUTO_THRESHOLD=0.8
USE_CALIBRATED_CONFIDENCE=true

# ---- Media Path ----
# Mount point for your video files (read-only inside the container)
VIDEO_MEDIA_PATH=/media/videos

# ---- UI ----
UI_PORT=3001
UI_API_URL=
